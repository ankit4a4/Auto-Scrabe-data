# Rename this file to .env and fill in your real values
# NEVER share your real .env file or paste real keys/passwords anywhere (chat, GitHub, etc.)

PORT=4000

# ============================================================
# ADMIN PANEL LOGIN (required) — the browser will show a login
# prompt; nothing works until these are entered correctly.
# ============================================================
ADMIN_USERNAME=your_username_here
ADMIN_PASSWORD=your_strong_password_here

# ============================================================
# AI PROVIDERS — set at least ONE API key.
# The more you add, the FASTER scraping goes (they're automatically
# rotated round-robin to increase combined throughput).
# ============================================================

# --- 1) Gemini (Google AI Studio - aistudio.google.com) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MIN_INTERVAL_MS=4200

# --- 2) Groq (console.groq.com) - free sign-up, no credit card ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MIN_INTERVAL_MS=2100

# --- 3) OpenRouter (openrouter.ai) - free sign-up, no credit card ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MIN_INTERVAL_MS=3100

# How many posts to process in parallel (keep low to avoid getting blocked)
CONCURRENCY=3

# Timeout (ms) for page loads
PAGE_TIMEOUT=25000

# --- Pagination safety ---
# Max pages to try while crawling category pagination
MAX_PAGES_TO_CRAWL=15

# Max click/step attempts for JS-driven pagination (Load More button OR
# numbered Next-arrow) - a safety cap so we don't click endlessly on
# heavy categories (e.g. 100-page listings)
MAX_PAGINATION_STEPS=8

# --- Date-range based scraping ---
# Safety cap: if a date range yields too many posts, only this many are
# processed (the rest are truncated, with a note in the log)
MAX_DATE_RANGE_POSTS=30
